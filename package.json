{
  "name": "frontend-starter",
  "author": "Ecaterina Sevciuc",
  "description": "A simple, responsive, and accessible frontend starter template built with Vite and TypeScript.",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"ts/**/*.{ts,tsx}\" --ext .ts,.tsx && eslint . --ext .js,.jsx --ignore-pattern \"dist/**\" --ignore-pattern \"node_modules/**\"",
    "format": "prettier --write \"**/*.{js,ts,css,scss,json,md}\"",
    "test": "vitest --environment jsdom"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}